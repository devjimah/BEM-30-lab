PORT=3000
MONGODB_URI=mongodb://localhost:27017/task_tracker_db
# Optional Atlas cloud connection. When set, it takes precedence over MONGODB_URI.
MONGODB_ATLAS_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?appName=Cluster0
NODE_ENV=development
# JWT configuration — generate a strong random secret (e.g. openssl rand -hex 64)
JWT_SECRET=your_strong_jwt_secret_here
JWT_EXPIRES_IN=1h
